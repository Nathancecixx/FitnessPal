FITNESSPAL_POSTGRES_DB=fitnesspal
FITNESSPAL_POSTGRES_USER=fitnesspal
FITNESSPAL_POSTGRES_PASSWORD=replace-with-a-unique-postgres-password
FITNESSPAL_DATABASE_URL=postgresql+psycopg://fitnesspal:replace-with-a-unique-postgres-password@postgres:5432/fitnesspal
FITNESSPAL_ADMIN_USERNAME=owner
FITNESSPAL_ADMIN_PASSWORD=replace-with-a-strong-admin-password
FITNESSPAL_PASSWORD_SETUP_HOURS=72
FITNESSPAL_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080
FITNESSPAL_CONFIG_SECRET=replace-with-a-long-random-secret-at-least-32-characters
FITNESSPAL_ALLOWED_AI_HOSTS=api.openai.com,api.anthropic.com,localhost,127.0.0.1,::1,host.docker.internal
FITNESSPAL_MAX_UPLOAD_BYTES=8388608
FITNESSPAL_LOGIN_RATE_LIMIT_ATTEMPTS=10
FITNESSPAL_LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
FITNESSPAL_ENFORCE_SECURE_BOOTSTRAP=true
FITNESSPAL_LOCAL_AI_BASE_URL=http://host.docker.internal:11434/v1
FITNESSPAL_LOCAL_AI_MODEL=qwen3-vl:8b
FITNESSPAL_LOCAL_AI_TIMEOUT_SECONDS=90
FITNESSPAL_BARCODE_LOOKUP_BASE_URL=https://world.openfoodfacts.org
FITNESSPAL_BARCODE_LOOKUP_TIMEOUT_SECONDS=10
FITNESSPAL_BARCODE_LOOKUP_USER_AGENT=FitnessPal/0.1.0
